# Git Line Ending Configuration
# This ensures consistent line endings across Windows, Mac, and Linux

# Auto detect text files and normalize to LF in repository
* text=auto eol=lf

# Source code files - always LF
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# Configuration files - always LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.conf text eol=lf
*.config text eol=lf
*.env text eol=lf
.env.* text eol=lf

# Documentation - always LF
*.md text eol=lf
*.txt text eol=lf

# Shell scripts - always LF (critical for Linux)
*.sh text eol=lf

# Docker files - always LF
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf

# Prisma schema - always LF
*.prisma text eol=lf

# Lock files - always LF
package-lock.json text eol=lf
pnpm-lock.yaml text eol=lf
yarn.lock text eol=lf

# Git files - always LF
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
