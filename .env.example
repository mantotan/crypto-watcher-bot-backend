# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@crypto_watcher_trade_db:5432/crypto_watcher_trade?schema=public"

# JWT Configuration
# IMPORTANT: Change these secrets in production! Use strong, randomly generated strings.
# You can generate secure secrets using: openssl rand -base64 32

# Access Token Secret (used for short-lived access tokens)
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this-in-production"

# Access Token Expiration (SECURITY: Recommended 15m-1h for production)
# Examples: 15m, 30m, 1h, 24h
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh Token Secret (used for long-lived refresh tokens)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Refresh Token Expiration (examples: 7d, 30d, 90d)
JWT_REFRESH_EXPIRES_IN="7d"

# Application Configuration
# NODE_ENV="development"
PORT="3733"

# Swagger/OpenAPI Documentation
# IMPORTANT: Swagger is automatically disabled in production for security
# Set to "true" to enable Swagger UI in production (not recommended)
# Access at: http://localhost:3733/api/docs (when enabled)
ENABLE_SWAGGER="false"

# Redis Configuration (for backtest queue)
REDIS_HOST="localhost"
REDIS_PORT="6333"
REDIS_PASSWORD=""
REDIS_DB="0"

# GraphQL Chart Data Service (for fetching candle data)
GRAPHQL_CHART_SERVICE_URL="http://localhost:8000/graphql"

# Email Configuration (Lark/Feishu)
# IMPORTANT: Update these with your actual Lark email credentials
# For Lark international: smtp.feishu.cn
# For Feishu (China): smtp.feishu.cn
EMAIL_HOST="smtp.feishu.cn"
EMAIL_PORT="465"
EMAIL_SECURE="true"
EMAIL_USER="your-email@yourcompany.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="noreply@yourcompany.com"

# Verification Code Settings
# Email verification code expiry time (in minutes)
EMAIL_VERIFICATION_CODE_EXPIRY_MINUTES="30"

# Password reset code expiry time (in minutes)
PASSWORD_RESET_CODE_EXPIRY_MINUTES="15"

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add this exact callback URL to "Authorized redirect URIs" in Google Console:
#   - http://localhost:3733/auth/google/callback (for development)
#   - https://yourdomain.com/auth/google/callback (for production)
# This single callback handles both login and account linking (differentiated by state parameter)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3733/auth/google/callback"

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"

# Cookie Configuration
# Domain for HTTP-only authentication cookies
# Development: Leave unset (defaults to localhost)
# Production: Use parent domain with leading dot to share across subdomains
# Example: COOKIE_DOMAIN=.example.com allows cookies on both bot.example.com and bot-api.example.com
# IMPORTANT: Leading dot is required for subdomain sharing
COOKIE_DOMAIN=""

# Encryption Configuration
# CRITICAL: Generate a secure 32-byte (64 hex characters) key for AES-256-GCM encryption
# Used for encrypting TOTP secrets and trading account API keys
# Generate using: openssl rand -hex 32
ENCRYPTION_KEY="your-64-character-hex-string-generated-by-openssl-rand-hex-32-command"

# Two-Factor Authentication Configuration
TWO_FACTOR_RATE_LIMIT_ATTEMPTS="5"
TWO_FACTOR_RATE_LIMIT_WINDOW_MINUTES="15"
